{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Another Dimension Chat",
  "version": "0.1.0",
  "identifier": "chat.anotherdimension.prototype",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Another Dimension Chat",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

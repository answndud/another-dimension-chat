{
  "schema_version": 1,
  "status": "source-boundary-authorization-hold-regression-matrix",
  "authorization_hold_regression_matrix_verified": true,
  "owner_authorization_for_callable_ffi": false,
  "explicit_callable_ffi_implementation_request": false,
  "source_roots": [
    "apps/mobile/ffi",
    "apps/mobile/android",
    "apps/mobile/ios"
  ],
  "forbidden_file_extensions": [
    ".udl",
    ".uniffi",
    ".aar",
    ".apk",
    ".aab",
    ".ipa",
    ".xcarchive"
  ],
  "forbidden_path_fragments": [
    "/generated/",
    "/bindings/",
    "/jniLibs/",
    "/cpp/",
    "/native/",
    "/release/",
    "/public-release/",
    "/beta-artifacts/"
  ],
  "forbidden_android_source_patterns": [
    "external fun",
    "System.loadLibrary",
    "JNIEnv",
    "NativeLibrary",
    "java.net.Socket",
    "HttpURLConnection",
    "FirebaseMessaging",
    "WorkManager"
  ],
  "forbidden_ios_source_patterns": [
    "@_silgen_name",
    "@CName",
    "dlopen",
    "UnsafeMutableRawPointer",
    "UnsafeRawPointer",
    "URLSession",
    "NWConnection",
    "UNUserNotificationCenter"
  ],
  "forbidden_claim_patterns": [
    "mobile readiness claimed true",
    "security-ready claimed true",
    "callable FFI implemented true",
    "generated bindings claimed true",
    "production-ready",
    "audited",
    "sensitive communication allowed"
  ],
  "allowed_documentation_paths": [
    "apps/mobile/ffi/README.md",
    "apps/mobile/ffi/*.json"
  ],
  "regression_outputs": [
    "forbidden_file_extensions=absent",
    "forbidden_path_fragments=absent",
    "forbidden_android_source_patterns=absent",
    "forbidden_ios_source_patterns=absent",
    "forbidden_claim_patterns=absent"
  ]
}
